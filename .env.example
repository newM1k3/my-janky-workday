# MJW Janky Workday — Environment Variables
# Copy to .env.local for local development

# PocketBase (IdeaCapture + ChatTasks frontend direct writes, open rules)
VITE_POCKETBASE_URL=https://mjwdesign-core.pockethost.io

# --- Netlify Function secrets (set in Netlify dashboard, NOT in .env) ---
# EscapeStock — PocketBase admin credentials for server-side auth
PB_ADMIN_EMAIL=sessionthoughts@gmail.com
PB_ADMIN_PASSWORD=<your-pb-admin-password>

# GitHub Activity
GITHUB_TOKEN=<ghp_...>

# Trello — Escape Maze org
TRELLO_API_KEY=<your-trello-api-key>
TRELLO_TOKEN=<your-trello-token>

# Google Calendar + Homebase Gmail parsing (same OAuth credentials)
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REFRESH_TOKEN=<your-google-refresh-token>
